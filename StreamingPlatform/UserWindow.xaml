<Window x:Class="StreamingPlatform.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StreamingPlatform"
        mc:Ignorable="d"
        Title="StreamingPlatform" Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#121212">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- БОКОВОЕ МЕНЮ -->
        <Border Grid.Column="0" Background="#000000">
            <StackPanel Margin="16,24,16,16">

                <!-- Лого -->
                <TextBlock Text="🎵 StreamingPlatform"
                           Foreground="#1DB954" FontSize="15" FontWeight="Bold"
                           Margin="0,0,0,32"/>

                <!-- Навигация -->
                <Button x:Name="BtnTracks" Content="🎵  Треки"
                        HorizontalContentAlignment="Left"
                        Padding="12,10" Margin="0,0,0,4"
                        Background="#1DB954" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Click="BtnTracks_Click"/>

                <Button x:Name="BtnPlaylists" Content="📋  Мои плейлисты"
                        HorizontalContentAlignment="Left"
                        Padding="12,10" Margin="0,0,0,4"
                        Background="Transparent" Foreground="#aaaaaa"
                        FontWeight="Bold" BorderThickness="0"
                        Click="BtnPlaylists_Click"/>

                <!-- Разделитель -->
                <Separator Background="#333" Margin="0,20,0,20"/>

                <!-- Приветствие -->
                <TextBlock x:Name="WelcomeText"
                           Foreground="#aaaaaa" FontSize="12"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="SubText"
                           Foreground="#555" FontSize="11"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- КОНТЕНТ -->
        <Grid Grid.Column="1" Margin="24,24,24,16">

            <!-- ===== ВКЛАДКА: ТРЕКИ ===== -->
            <StackPanel x:Name="PanelTracks">

                <TextBlock Text="Каталог треков" Foreground="White"
                           FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Поиск -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox"
                             Height="36" Padding="10,6"
                             Background="#2a2a2a" Foreground="White"
                             BorderBrush="#444" CaretBrush="White"
                             Text="Поиск треков..."
                             GotFocus="SearchBox_GotFocus"
                             LostFocus="SearchBox_LostFocus"
                             TextChanged="SearchBox_TextChanged"/>
                </Grid>

                <!-- Список треков -->
                <ListView x:Name="TracksList"
                          Background="Transparent" BorderThickness="0"
                          Foreground="White" MaxHeight="420"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2a2a2a"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1DB95433"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="🎵 Название" Width="280"
                                            DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="⏱ Длительность" Width="140"
                                            DisplayMemberBinding="{Binding DurationFormatted}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Кнопка добавить в плейлист -->
                <Border Background="#1a1a1a" CornerRadius="8"
                        Padding="16" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Добавить трек в плейлист"
                                       Foreground="White" FontWeight="Bold"/>
                            <ComboBox x:Name="PlaylistPicker"
                                      Margin="0,6,0,0" Height="30"
                                      Background="#2a2a2a" Foreground="White"
                                      DisplayMemberPath="PlaylistName"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="＋ Добавить"
                                Width="110" Height="34"
                                Margin="12,0,0,0" VerticalAlignment="Bottom"
                                Background="#1DB954" Foreground="White"
                                FontWeight="Bold" BorderThickness="0"
                                Click="AddToPlaylist_Click"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ===== ВКЛАДКА: ПЛЕЙЛИСТЫ ===== -->
            <StackPanel x:Name="PanelPlaylists" Visibility="Collapsed">

                <TextBlock Text="Мои плейлисты" Foreground="White"
                           FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Создать новый -->
                <Border Background="#1a1a1a" CornerRadius="8"
                        Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Новый плейлист"
                                       Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBox x:Name="NewPlaylistName"
                                     Height="30" Padding="8,4"
                                     Background="#2a2a2a" Foreground="White"
                                     BorderBrush="#444" CaretBrush="White"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Создать"
                                Width="90" Height="34"
                                Margin="12,20,0,0"
                                Background="#1DB954" Foreground="White"
                                FontWeight="Bold" BorderThickness="0"
                                Click="CreatePlaylist_Click"/>
                    </Grid>
                </Border>

                <!-- Список плейлистов -->
                <ListBox x:Name="PlaylistsList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" MaxHeight="200"
                         SelectionChanged="PlaylistsList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding PlaylistName}"
                                       Padding="8,6" FontSize="14"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1DB95433"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Треки выбранного плейлиста -->
                <TextBlock x:Name="PlaylistTracksTitle"
                           Foreground="#aaaaaa" FontSize="13"
                           Margin="0,16,0,8"/>

                <ListView x:Name="PlaylistTracksList"
                          Background="Transparent" BorderThickness="0"
                          Foreground="White" MaxHeight="200"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8,5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2a2a2a"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="🎵 Название" Width="260"
                                            DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="⏱ Длительность" Width="130"
                                            DisplayMemberBinding="{Binding DurationFormatted}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
