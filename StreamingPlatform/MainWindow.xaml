<Window x:Class="StreamingPlatform.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StreamingPlatform"
        mc:Ignorable="d"
        Title="Streamify"
        Height="720"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        ResizeMode="CanMinimize"
        Icon="Assets/icon.ico">

    <Grid>

        <Grid.Resources>

            <Style TargetType="Button">

                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>

            </Style>

        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Background="#181818"
                Grid.Row="0">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- ЛОГО -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">

                    <Image Source="/Assets/icon.png"
                           Width="45"
                           Height="45"
                           Margin="0,0,10,0"/>

                    <TextBlock Text="Streamify"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                </StackPanel>

                <!-- ПОИСК -->
                <Border Grid.Column="2"
                        Width="240"
                        Height="40"
                        Background="#2A2A2A"
                        CornerRadius="10"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">

                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             FontSize="15"
                             Padding="15,8,15,8"
                             VerticalContentAlignment="Center"
                             TextChanged="SearchBox_TextChanged"/>

                </Border>

            </Grid>

        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВОЕ МЕНЮ -->
            <Border Background="#181818"
                    Grid.Column="0">

                <StackPanel Margin="10">

                    <TextBlock Text="НАВИГАЦИЯ"
                               Foreground="#B3B3B3"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="10"/>

                    <Button x:Name="UsersButton"
                            Height="55"
                            Margin="5"
                            Background="#282828"
                            Foreground="White"
                            Click="UsersButton_Click">

                        <StackPanel Orientation="Horizontal">

                            <Image Source="/Assets/catmusic.png"
                                   Width="24"
                                   Height="24"
                                   Margin="10,0,0,0"/>

                            <TextBlock Text="Пользователи"
                                       FontSize="16"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="TracksButton"
                            Height="55"
                            Margin="5"
                            Background="#282828"
                            Foreground="White"
                            Click="TracksButton_Click">

                        <StackPanel Orientation="Horizontal">

                            <Image Source="Assets/music.png"
                                   Width="24"
                                   Height="24"
                                   Margin="10,0,0,0"/>

                            <TextBlock Text="Треки"
                                       FontSize="16"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>

                    <Button x:Name="PlaylistsButton"
                            Height="55"
                            Margin="5"
                            Background="#282828"
                            Foreground="White"
                            Click="PlaylistsButton_Click">

                        <StackPanel Orientation="Horizontal">

                            <Image Source="Assets/playlist.png"
                                   Width="24"
                                   Height="24"
                                   Margin="10,0,0,0"/>

                            <TextBlock Text="Плейлисты"
                                       FontSize="16"
                                       Margin="15,0,0,0"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>

                </StackPanel>

            </Border>

            <!-- ПРАВАЯ ЧАСТЬ -->
            <Grid Grid.Column="1"
                  Margin="15">

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ПАНЕЛЬ УПРАВЛЕНИЯ -->
                <Border Background="#1E1E1E"
                        CornerRadius="12"
                        Grid.Row="0">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10">

                        <!-- ДОБАВИТЬ -->
                        <Button Width="170"
                                Height="45"
                                Margin="5"
                                Background="#1DB954"
                                Foreground="White"
                                FontSize="15"
                                Click="AddButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                           FontSize="18"
                                           Margin="0,0,10,0"/>

                                <TextBlock Text="Добавить"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <!-- УДАЛИТЬ -->
                        <Button Width="170"
                                Height="45"
                                Margin="5"
                                Background="#E53935"
                                Foreground="White"
                                FontSize="15"
                                Click="DeleteButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                           FontSize="18"
                                           Margin="0,0,10,0"/>

                                <TextBlock Text="Удалить"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <!-- ОБНОВИТЬ -->
                        <Button Width="170"
                                Height="45"
                                Margin="5"
                                Background="#3A86FF"
                                Foreground="White"
                                FontSize="15"
                                Click="RefreshButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock
                                           FontSize="18"
                                           Margin="0,0,10,0"/>

                                <TextBlock Text="Обновить"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                        <Button Width="170"
        Height="45"
        Margin="5"
        Background="#FFB300"
        Foreground="White"
        FontSize="15"
        Click="SaveButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="Сохранить"
                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Border>

                <!-- ТАБЛИЦА -->
                <Border Background="#1E1E1E"
                        CornerRadius="12"
                        Grid.Row="1"
                        Margin="0,15,0,0">

                    <DataGrid x:Name="MainGrid"
                              Margin="10"
                              AutoGenerateColumns="True"
                              Background="#1E1E1E"
                              Foreground="White"
                              BorderBrush="#1E1E1E"
                              RowBackground="#252525"
                              AlternatingRowBackground="#2F2F2F"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              FontSize="15"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              IsReadOnly="False"
                              RowEditEnding="MainGrid_RowEditEnding"
                              AddingNewItem="MainGrid_AddingNewItem">

                        <!-- ЗАГОЛОВКИ -->
                        <DataGrid.ColumnHeaderStyle>

                            <Style TargetType="DataGridColumnHeader">

                                <Setter Property="Background"
                                        Value="#1DB954"/>

                                <Setter Property="Foreground"
                                        Value="Black"/>

                                <Setter Property="FontWeight"
                                        Value="Bold"/>

                                <Setter Property="FontSize"
                                        Value="15"/>

                                <Setter Property="Height"
                                        Value="42"/>

                                <Setter Property="BorderBrush"
                                        Value="#121212"/>

                                <Setter Property="BorderThickness"
                                        Value="1"/>

                                <Setter Property="Padding"
                                        Value="10,0,10,0"/>

                                <Setter Property="HorizontalContentAlignment"
                                        Value="Center"/>

                                <Setter Property="VerticalContentAlignment"
                                        Value="Center"/>

                            </Style>

                        </DataGrid.ColumnHeaderStyle>

                        <!-- ЯЧЕЙКИ -->
                        <DataGrid.CellStyle>

                            <Style TargetType="DataGridCell">

                                <Setter Property="BorderBrush"
                                        Value="#404040"/>

                                <Setter Property="BorderThickness"
                                        Value="0.5"/>

                                <Setter Property="Padding"
                                        Value="5"/>

                            </Style>

                        </DataGrid.CellStyle>

                    </DataGrid>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
